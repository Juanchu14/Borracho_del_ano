# Puerto en el que escucha la aplicación
PORT=3000

# Conexión a PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=borracho_del_ano
DB_USER=borracho_app
DB_PASSWORD=cambia_esta_contrasena

# Secreto para firmar los tokens de sesión (JWT).
# Genera uno fuerte con: openssl rand -hex 64
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

# Cuánto dura la sesión antes de tener que volver a iniciar sesión
JWT_EXPIRES_IN=30d
